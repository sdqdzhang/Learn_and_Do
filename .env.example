# ============================================================
# Tiny-Devin runtime configuration. Copy to `.env` (git-ignored).
# ============================================================

# ---------- LLM (Ollama via OpenAI-compatible API) ----------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=your-model-name
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2

# Optional secondary model used for summarization / reflection
# (defaults to OLLAMA_MODEL if unset)
LLM_SUMMARIZER_MODEL=

# ---------- Docker sandbox ----------
DOCKER_BASE_IMAGE=tiny-devin-base:latest
CONTAINER_NAME_PREFIX=tiny-devin
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_LIMIT=2.0
CONTAINER_IDLE_TIMEOUT_SECONDS=3600
CONTAINER_HEARTBEAT_INTERVAL_SECONDS=600
# Default per-script wall-clock timeout, seconds.
EXECUTOR_DEFAULT_TIMEOUT=60

# ---------- Workspace & traces ----------
WORKSPACE_DIR=./runtime/workspace
TRACE_DIR=./runtime/traces

# ---------- Memory ----------
# Short-term context budget (in tokens). When exceeded the summarizer kicks in.
CONTEXT_MAX_TOKENS=8000

# tiktoken encoding name. Use "cl100k_base" for OpenAI-style; for local
# models, "cl100k_base" is a reasonable proxy.
CONTEXT_TIKTOKEN_ENCODING=cl100k_base

# Vector store
VECTOR_PERSIST_DIR=./runtime/vector_store
VECTOR_COLLECTION=tiny-devin

# ---------- Workflow ----------
# Hard upper bound on number of THINK-ACT-OBSERVE-REFLECT loops per session.
WORKFLOW_MAX_TURNS=10

# ---------- Logging ----------
LOG_LEVEL=INFO
