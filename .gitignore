*.local

# ---------- Tiny-Devin runtime artifacts ----------
# Workspace is shared with the sandbox container; track folder, ignore content.
runtime/workspace/*
!runtime/workspace/.gitkeep

# Trace logs (one .jsonl per session)
runtime/traces/*
!runtime/traces/.gitkeep

# WebSocket 会话轨迹（前端可回放，见 server TraceLogger log_dir）
log/*.jsonl
!log/.gitkeep

# Local vector store (ChromaDB persistent files)
runtime/vector_store/
